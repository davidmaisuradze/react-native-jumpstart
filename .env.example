# Firebase (configured via google-services.json and GoogleService-Info.plist)
# Note: Firebase credentials are in the config files, not environment variables
# Download from Firebase Console:
# - iOS: GoogleService-Info.plist -> place in project root
# - Android: google-services.json -> place in project root
# EXPO_PUBLIC_FIREBASE_DYNAMIC_LINK_DOMAIN=yourapp.page.link

# Google Sign-In OAuth Client IDs
# Web client ID is required - used by @react-native-google-signin for ID token exchange
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# iOS client ID (from GoogleService-Info.plist CLIENT_ID field)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
# Note: Android client ID is in google-services.json (add SHA-1 fingerprint in Firebase Console first)

# RevenueCat
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=your-revenuecat-ios-key
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=your-revenuecat-android-key

# Sentry
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn

# PostHog
EXPO_PUBLIC_POSTHOG_API_KEY=your-posthog-api-key
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com
